{
  "name": "weibo-extend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clear:terminal": "tput reset",
    "zip:extension": "rm -rf weibo-extend.zip && cd ./extension && zip -r ../weibo-extend.zip . && cd ..",
    "pack:extensionscript": "webpack --config ./extension.webpack.config.js",
    "bun:pack": "bun ./bunpack.ts",
    "build:extension": "npm run clear:terminal && npm run weibosave && npm run prettier && npm run pack:extensionscript && npm run css:virtualpage && npm run zip:extension",
    "bun:extension": "npm run clear:terminal && npm run weibosave && bun run prettier && bun ./bunpack.ts && npm run css:virtualpage && npm run zip:extension",
    "css:virtualpage": "npx tailwindcss -c ./virtualpage.tailwind.config.ts -i ./app/scripts/reactVirtual/style/virtualPage.css -o ./extension/virtualPage.output.css --minify",
    "css:weibosave": "npx tailwindcss -c ./weibosave.tailwind.config.ts -i ./weiboSave/style/weibosave.css -o ./extension/weiboSave/style/weibosave.css --minify",
    "pack:weibsave": "webpack --config ./weibosave.webpack.config.js",
    "weibosave": "npm run pack:weibsave && npm run css:weibosave",
    "check-types": "tsc --noemit",
    "prettier:single": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write",
    "prettier": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write \"app/**/*.{js,jsx,ts,tsx}\" \"weiboSave/**/*.{js,ts,html,css}\" \"*.{js,ts}\"",
    "prettier:check": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --check \"app/**/*.{js,jsx,ts,tsx}\" \"weiboSave/**/*.{js,ts,html,css}\" \"*.{js,ts}\""
  },
  "keywords": [
    "chrome",
    "extension",
    "weibo",
    "backup"
  ],
  "author": "loo-y",
  "license": "ISC",
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "dayjs": "^1.11.10",
    "file-saver": "^2.0.5",
    "jquery": "^3.7.1",
    "js-cookie": "^3.0.5",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "react": "^18",
    "react-dom": "^18",
    "react-redux": "^8.1.3",
    "tailwind-datepicker-react": "^1.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "@types/lodash": "^4.14.199",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "html-webpack-plugin": "^5.5.3",
    "postcss": "^8",
    "prettier": "^3.0.3",
    "tailwindcss": "^3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
